.DS_Store

# iCloud sync conflict copies of sandbox files (e.g. ".devcontainer/squid 2.conf").
# Scoped to .devcontainer so it can't swallow legit vault notes like "Chapter 2.md".
# The git remote is the source of truth for these scripts.
.devcontainer/* [0-9].*
.devcontainer/* [0-9]

.claude
.ruff_cache
__pycache__

# Obsidian: ignore workspace state and personal UI preferences. Carve out
# scaffold-relevant plugin settings (Templater folder templates) so they
# travel with the skeleton repo. Add more plugin data.json files here if
# their settings become part of the scaffold.
.obsidian/*
!.obsidian/plugins/
.obsidian/plugins/*
!.obsidian/plugins/templater-obsidian/
.obsidian/plugins/templater-obsidian/*
!.obsidian/plugins/templater-obsidian/data.json

raw/assets/*
raw/inbox/*
raw/sources/*
raw/sources-text/*
wiki/comparisons/*
wiki/concepts/*
wiki/entities/*
wiki/queries/*
wiki/reports/*
wiki/sources/*
wiki/syntheses/*
wiki/topics/*
wiki/log.md
wiki/index.md

projects/*/
!.gitkeep
