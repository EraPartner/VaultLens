.DS_Store
# macOS custom-folder-icon resource (a file literally named "Icon" + CR).
Icon?

# Agent-scratch append-log payloads. wiki-enhancer/wiki-cos write a temp JSON
# entry then call `wiki.py append-log --from-json`; agents sometimes write it
# in-tree instead of /tmp/ and leave .bak/.done renames behind. The agent prompt
# now mandates an absolute /tmp/ path; these patterns are the belt-and-braces.
*.json.bak
*.json.done
wiki-log-*.json

# iCloud sync conflict copies of sandbox files (e.g. ".devcontainer/squid 2.conf").
# Scoped to .devcontainer so it can't swallow legit vault notes like "Chapter 2.md".
# The git remote is the source of truth for these scripts.
.devcontainer/* [0-9].*
.devcontainer/* [0-9]

# Claude config: track CLAUDE.md, .claude/agents/, .claude/skills/, .claude/settings.json;
# only machine-local state stays ignored.
.claude/settings.local.json
.claude/worktrees/
.ruff_cache
__pycache__

# Obsidian: ignore workspace state and personal UI preferences. Carve out
# scaffold-relevant plugin settings (Templater folder templates) so they
# travel with the skeleton repo. Add more plugin data.json files here if
# their settings become part of the scaffold.
.obsidian/*
!.obsidian/plugins/
.obsidian/plugins/*
!.obsidian/plugins/templater-obsidian/
.obsidian/plugins/templater-obsidian/*
!.obsidian/plugins/templater-obsidian/data.json

raw/assets/*
raw/inbox/*
raw/sources/*
raw/sources-text/*
wiki/comparisons/*
wiki/concepts/*
wiki/entities/*
wiki/queries/*
wiki/reports/*
wiki/sources/*
wiki/syntheses/*
wiki/topics/*
wiki/log.md
wiki/index.md

projects/*/
!.gitkeep

# Generated TODO aggregators (live `TODO.md` + iOS `TODO-widget.md`), rebuilt per
# device by tools/scripts/rebuild-projects-todo.sh. Device-local task tracking,
# not version-controlled. (Per-project projects/<slug>/TODO.md are ignored above
# via `projects/*/`.)
projects/TODO*.md
