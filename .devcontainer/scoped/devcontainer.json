// SCOPED (read-only workspace) variant of ../devcontainer.json.
//
// Lives in its own subdir because the devcontainer CLI requires every config to
// be named exactly `devcontainer.json`; bin/agent selects it with `--config` for
// every profile EXCEPT `master` (reader, author, project:<X>, raw, projects).
// The ONLY behavioural difference from ../devcontainer.json is `workspaceMount`
// (read-only here): the vault is mounted read-only and bin/agent punches a single
// read-write hole for the profile's scope via `devcontainer up --mount` (e.g.
// wiki/ for author, projects/<X>/ for a project agent). reader gets no hole.
//
// build/feature paths are "../" because this file sits one level below the real
// .devcontainer contents (Dockerfile, features/). Lifecycle commands stay
// `.devcontainer/...` (they resolve against the workspace folder, not this file).
//
// KEEP IN SYNC with ../devcontainer.json — everything except workspaceMount /
// workspaceFolder and the ../ build paths must mirror it.
{
  "name": "Brain Dev (scoped)",
  // Container path is hardcoded (not ${containerWorkspaceFolder}): that variable
  // is DERIVED from workspaceFolder, so referencing it from workspaceFolder/
  // workspaceMount is circular and ends up passed to docker literally.
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspaces/Brain,type=bind,readonly",
  "workspaceFolder": "/workspaces/Brain",
  "build": {
    "dockerfile": "../Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    },
    "ghcr.io/devcontainers/features/python:1": {
      "version": "3.12",
      "installTools": false
    },
    "ghcr.io/anthropics/devcontainer-features/claude-code:1.0": {},
    "../features/agent-clis": {}
  },
  "init": true,
  "overrideCommand": false,
  "containerUser": "root",
  "remoteUser": "dev",
  "runArgs": [
    "--cap-drop=ALL",
    "--cap-add=NET_ADMIN",
    "--cap-add=CHOWN",
    "--cap-add=DAC_OVERRIDE",
    "--cap-add=FOWNER",
    "--cap-add=SETUID",
    "--cap-add=SETGID",
    "--cap-add=SETPCAP",
    "--security-opt=no-new-privileges",
    "--memory=6g",
    "--cpus=4",
    "--pids-limit=4096",
    "--tmpfs=/tmp:rw,noexec,nosuid,nodev,size=512m",
    "--tmpfs=/var/tmp:rw,noexec,nosuid,nodev,size=256m",
    "--add-host=host.docker.internal:host-gateway"
  ],
  "mounts": [
    // The whole workspace is already read-only via workspaceMount above; these
    // overlays are redundant here but kept identical to ../devcontainer.json so
    // the two files stay structurally parallel. .git stays read-only even when a
    // profile's RW hole is elsewhere; the nested projects/thesis/.git is left
    // writable (it falls under a project:thesis RW hole, not this overlay).
    "source=${localWorkspaceFolder}/.devcontainer,target=/workspaces/Brain/.devcontainer,type=bind,readonly",
    "source=${localWorkspaceFolder}/.git,target=/workspaces/Brain/.git,type=bind,readonly",
    // Home volumes are keyed by ${localEnv:BRAIN_VOL_KEY} (set by bin/agent), NOT
    // ${devcontainerId}: all project:<X> profiles share one key ("<root>-project")
    // so switching projects reuses the seeded qmd index / claude config instead
    // of re-seeding per project. reader/author/raw/projects keep their own key.
    "source=brain-claude-${localEnv:BRAIN_VOL_KEY},target=/home/dev/.claude,type=volume",
    "source=brain-copilot-${localEnv:BRAIN_VOL_KEY},target=/home/dev/.copilot,type=volume",
    "source=brain-local-${localEnv:BRAIN_VOL_KEY},target=/home/dev/.local,type=volume",
    "source=brain-config-${localEnv:BRAIN_VOL_KEY},target=/home/dev/.config,type=volume",
    "source=brain-cache-${localEnv:BRAIN_VOL_KEY},target=/home/dev/.cache,type=volume",
    "source=${localEnv:HOME}/.claude-brain-stage,target=/home/dev/.claude-stage,type=bind,readonly",
    "source=${localEnv:HOME}/.cache/qmd,target=/home/dev/.qmd-seed,type=bind,readonly",
    "source=${localEnv:HOME}/Documents/School,target=${localEnv:HOME}/Documents/School,type=bind,readonly",
    "source=${localEnv:HOME}/Documents/Personal/Scripts/Projects/Vision,target=${localEnv:HOME}/Documents/Personal/Scripts/Projects/Vision,type=bind,readonly",
    "source=${localEnv:HOME}/Documents/Personal/Scripts/Projects/Watchman,target=${localEnv:HOME}/Documents/Personal/Scripts/Projects/Watchman,type=bind,readonly",
    "source=${localEnv:HOME}/Documents/Personal/Scans/Finance/The Mad King,target=${localEnv:HOME}/Documents/Personal/Scans/Finance/The Mad King,type=bind,readonly"
  ],
  "containerEnv": {
    "DEVCONTAINER": "true",
    "DISABLE_TELEMETRY": "1",
    "DISABLE_ERROR_REPORTING": "1",
    "BASH_ENV": "/home/dev/.safe-chain/scripts/init-posix.sh",
    "NODE_USE_ENV_PROXY": "1",
    "HTTP_PROXY": "http://127.0.0.1:3128",
    "HTTPS_PROXY": "http://127.0.0.1:3128",
    "http_proxy": "http://127.0.0.1:3128",
    "https_proxy": "http://127.0.0.1:3128",
    "NO_PROXY": "localhost,127.0.0.1,::1,host.docker.internal",
    "no_proxy": "localhost,127.0.0.1,::1,host.docker.internal",
    "OLLAMA_HOST": "http://host.docker.internal:11434",
    "QMD_EMBED_MODEL": "hf:Qwen/Qwen3-Embedding-0.6B-GGUF/Qwen3-Embedding-0.6B-Q8_0.gguf"
  },
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh"
}
