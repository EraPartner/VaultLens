#!/usr/bin/env bash
# Brain devcontainer readiness check. Run INSIDE the container:
#   brain-shell        # then:  .devcontainer/bin/doctor
#   # or directly:     container exec <brain-container> .devcontainer/bin/doctor
#
# Verifies the egress lock, the agent toolchain, qmd, the ollama hole, and auth.
# Exit non-zero if any CRITICAL check fails.

set -uo pipefail

pass=0; warn=0; fail=0
ok()   { printf '  \033[32m✓\033[0m %s\n' "$*"; pass=$((pass+1)); }
note() { printf '  \033[33m!\033[0m %s\n' "$*"; warn=$((warn+1)); }
bad()  { printf '  \033[31m✗\033[0m %s\n' "$*"; fail=$((fail+1)); }

echo "== Sandbox integrity =="
# The host-side launcher (.devcontainer/bin/agent|claude|doctor) and the sandbox
# definition (devcontainer.json runArgs, Dockerfile) live under .devcontainer and
# run on the HOST. If they are writable from inside, a compromised agent can
# rewrite them and escape on the next launch. The launcher mounts .devcontainer
# read-only, but that only applies on container CREATE — a stale container booted
# before the change leaves the door open. Prove it's live by trying to write, not
# by trusting the config.
DC_DIR="$(cd "$(dirname "$0")/.." 2>/dev/null && pwd -P || echo /workspaces/Brain/.devcontainer)"
_probe="$DC_DIR/.doctor-write-probe.$$"
if ( : > "$_probe" ) 2>/dev/null; then
  rm -f "$_probe" 2>/dev/null || true
  bad ".devcontainer is WRITABLE from inside — host launcher + run args can be tampered. REBUILD: BRAIN_REBUILD=1 brain-claude"
else
  ok ".devcontainer is read-only (host launcher + runArgs can't be rewritten from inside)"
fi

echo "== Egress lock =="
if [[ -f /run/egress-firewall-ok ]]; then ok "firewall sentinel present"; else bad "firewall sentinel missing (/run/egress-firewall-ok)"; fi
if pgrep -x squid >/dev/null 2>&1; then ok "squid running"; else bad "squid not running"; fi
if (exec 3<>/dev/tcp/127.0.0.1/3128) 2>/dev/null; then ok "proxy listening on 127.0.0.1:3128"; else bad "proxy not listening on :3128"; fi
if curl -sS --max-time 12 -o /dev/null -w '%{http_code}' https://api.anthropic.com/ 2>/dev/null | grep -qE '^[0-9]'; then
  ok "allowed host reachable via proxy (api.anthropic.com)"
else
  note "could not reach api.anthropic.com (network detached? check 'container logs')"
fi
if curl -sS --max-time 8 -o /dev/null https://example.com/ 2>/dev/null; then
  bad "DENIED host example.com was reachable — allowlist not enforced!"
else
  ok "denied host blocked (example.com)"
fi

echo "== Ollama hole (host daemon) =="
oll="${OLLAMA_HOST:-http://host.docker.internal:11434}"
if curl -sS --max-time 6 -o /dev/null "${oll}/api/tags" 2>/dev/null; then
  ok "host ollama reachable at ${oll}"
else
  note "host ollama not reachable at ${oll} (is 'ollama serve' running on the host?)"
fi

echo "== Agent toolchain =="
for c in claude qmd python3 pdftotext qpdf gh jq rsync git; do
  if command -v "$c" >/dev/null 2>&1; then ok "$c present"; else
    case "$c" in claude|qmd|python3|pdftotext) bad "$c MISSING";; *) note "$c missing";; esac
  fi
done
if command -v safe-chain >/dev/null 2>&1; then ok "safe-chain present"; else note "safe-chain missing (installs not screened)"; fi

echo "== qmd search =="
if command -v qmd >/dev/null 2>&1; then
  ls /home/dev/.cache/qmd/models/*.gguf >/dev/null 2>&1 && ok "embedding models seeded" || note "no GGUF models in ~/.cache/qmd/models"
  if qmd status >/dev/null 2>&1; then ok "qmd status OK"; else note "qmd status failed (run 'qmd update')"; fi
fi

echo "== Auth =="
[[ -n "${CLAUDE_CODE_OAUTH_TOKEN:-}" || -n "${ANTHROPIC_API_KEY:-}" ]] && ok "Claude token in env" || bad "no Claude token (set brain-claude-code-token in Keychain)"
# No git push credential is forwarded ON PURPOSE: commits/pushes happen on the
# HOST, and the root .git is mounted read-only. Its presence would be the bug.
[[ -z "${GH_TOKEN:-}${GITHUB_TOKEN:-}" ]] \
  && ok "no git push token in env (commits happen on the host — expected)" \
  || bad "GH_TOKEN/GITHUB_TOKEN present — a container must NOT hold a git push credential"

echo
echo "Summary: ${pass} ok, ${warn} warn, ${fail} fail"
(( fail == 0 ))
