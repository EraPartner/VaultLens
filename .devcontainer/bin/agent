#!/usr/bin/env bash
# Dispatcher for the Brain agent launchers. Every brain-* wrapper (brain-claude,
# brain-copilot, brain-opencode, brain-shell, brain-wiki) and the bin/claude shim
# call THIS file, so a single switch flips — or reverts — every entry point:
#
#   default            -> agent-compose      (devcontainer-free Docker Compose)
#   BRAIN_DEVCONTAINER=1 -> agent-devcontainer (legacy devcontainer launcher,
#                                               kept as a known-good fallback)
#
# Both back-ends honour the same env (BRAIN_PROFILE, BRAIN_WRITE_PATH,
# BRAIN_PROJECT_ROOT, BRAIN_AUTOSYNC, BRAIN_GH_ACCOUNT, BRAIN_DRYRUN, ...).
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd -P)"
if [[ -n "${BRAIN_DEVCONTAINER:-}" ]]; then
  exec "$here/agent-devcontainer" "$@"
else
  exec "$here/agent-compose" "$@"
fi
