#!/usr/bin/env bash
# apple/container launcher: route an agent command into the Brain sandbox.
# Docker-free successor to the former Docker Compose launcher.
# Capability profiles enforced by per-profile MOUNT flags instead of compose files:
#   master   -> workspace READ-WRITE
#   reader   -> workspace READ-ONLY, no hole
#   author   -> RO + RW hole wiki/
#   raw      -> RO + RW hole raw/
#   projects -> RO + RW hole projects/
#   project  -> RO + RW hole projects/<X>/
# .git + .devcontainer stay RO in every profile. Per-profile isolation = a distinct
# container NAME and its own home volumes (both keyed by BRAIN_VOL_KEY).
#
# apple/container deltas: `--init` = compose init:true; `--tmpfs` bare path only;
# no `--security-opt` (setuid stripped + VM boundary). OLLAMA DROPPED — no host
# reach, no extra_hosts, no OLLAMA_HOST; extra-rules.sh is a no-op stub.
set -euo pipefail

find_project_root() {
  local d="$PWD"
  while [[ "$d" != "/" ]]; do
    [[ -f "$d/.devcontainer/Dockerfile" ]] && { echo "$d"; return 0; }
    d="$(dirname "$d")"
  done
  return 1
}
if [[ -n "${BRAIN_PROJECT_ROOT:-}" && -d "${BRAIN_PROJECT_ROOT}/.devcontainer" ]]; then
  PROJECT_ROOT="$BRAIN_PROJECT_ROOT"
else
  PROJECT_ROOT="$(find_project_root || true)"
fi
[[ -z "$PROJECT_ROOT" || ! -d "$PROJECT_ROOT/.devcontainer" ]] && {
  echo "agent: cannot locate the Brain project root." >&2; exit 1; }

# Canonicalize (the vault root is a symlink); keep host PWD for cwd + profile math.
HOST_PWD="$(pwd -P)"
PROJECT_ROOT="$(cd "$PROJECT_ROOT" 2>/dev/null && pwd -P || printf '%s' "$PROJECT_ROOT")"
DC="$PROJECT_ROOT/.devcontainer"
CONTAINER_WS="/workspaces/$(basename "$PROJECT_ROOT")"

command -v container >/dev/null 2>&1 || { echo "agent: apple/container not installed." >&2; exit 1; }
container system status >/dev/null 2>&1 || { echo "agent: container system not started — run: container system start" >&2; exit 1; }

[[ $# -eq 0 ]] && set -- claude

# --- 0) Resolve capability profile + writable scope ---------------------------
PROFILE="${BRAIN_PROFILE:-}"
WRITE_PATH="${BRAIN_WRITE_PATH:-}"
if [[ -z "$PROFILE" ]]; then
  rel="${HOST_PWD#"$PROJECT_ROOT"}"; rel="${rel#/}"
  case "$rel" in
    projects/*) sub="${rel#projects/}"; sub="${sub%%/*}"
      if [[ -n "$sub" ]]; then PROFILE="project"; WRITE_PATH="projects/$sub"; else PROFILE="master"; fi ;;
    *) PROFILE="master" ;;
  esac
fi
case "$PROFILE" in
  master|reader)  WRITE_PATH="" ;;
  author)         WRITE_PATH="${WRITE_PATH:-wiki}" ;;
  raw)            WRITE_PATH="${WRITE_PATH:-raw}" ;;
  projects)       WRITE_PATH="${WRITE_PATH:-projects}" ;;
  project)        [[ -n "$WRITE_PATH" ]] || { echo "agent: profile 'project' needs BRAIN_WRITE_PATH=projects/<X>." >&2; exit 1; } ;;
  *) echo "agent: unknown BRAIN_PROFILE='$PROFILE' (master reader author project raw projects)." >&2; exit 1 ;;
esac
if [[ -n "$WRITE_PATH" && ! -d "$PROJECT_ROOT/$WRITE_PATH" ]]; then
  echo "agent: writable scope '$WRITE_PATH' does not exist under $PROJECT_ROOT." >&2; exit 1
fi

ROOT_HASH="$(printf '%s' "$PROJECT_ROOT" | shasum 2>/dev/null | cut -c1-12 || echo brain)"
if [[ "$PROFILE" == "project" ]]; then
  PROFILE_LABEL="proj-$(printf '%s' "${WRITE_PATH#projects/}" | tr '/' '-')"
else
  PROFILE_LABEL="$PROFILE"
fi
BRAIN_VOL_KEY="${ROOT_HASH}-${PROFILE_LABEL}"
NAME="brain-${ROOT_HASH}-${PROFILE_LABEL}"
IMAGE="brain:latest"
SVC_USER=dev

# --- 1) Build the per-profile mount list --------------------------------------
# Workspace: RW for master, RO for every scoped profile (+ a single RW hole).
WS_MOUNTS=()
if [[ "$PROFILE" == "master" ]]; then
  WS_MOUNTS+=(-v "$PROJECT_ROOT:$CONTAINER_WS")
else
  WS_MOUNTS+=(-v "$PROJECT_ROOT:$CONTAINER_WS:ro")
  [[ -n "$WRITE_PATH" ]] && WS_MOUNTS+=(-v "$PROJECT_ROOT/$WRITE_PATH:$CONTAINER_WS/$WRITE_PATH")
fi

# Source/personal symlink targets — derived PER RUN, not statically mounted.
# A vault symlink to a path OUTSIDE the vault (projects/vision/Vision -> ~/Code/Vision,
# projects/dep/DEP -> ~/Documents/School/DEP, …) dangles in-container unless its target is
# bind-mounted RO at the same absolute path. Instead of statically mounting all of School +
# every Code repo into EVERY run (audit BR1: needless PII/source exposure), mount ONLY the
# symlink targets the current run's scope can reach, and ONLY if the target is under an
# allowlisted root (fail-closed: anything else is skipped + warned, so a stray symlink can't
# pull in ~/.ssh). A scan project that symlinks only ~/Code/* therefore gets NO School/finance
# mount — PII is structurally absent from that run. Finance scans stay OPT-IN (audit BR1):
# their root is allowlisted only when BRAIN_MOUNT_FINANCE is set.
ALLOW_ROOTS=("$HOME/Code/Vision" "$HOME/Code/Watchman" "$HOME/Code/Napoleon-relay" "$HOME/Code/devcontainer-egress" "$HOME/Code/git-agent" "$HOME/Documents/School")
[[ -n "${BRAIN_MOUNT_FINANCE:-}" ]] && ALLOW_ROOTS+=("$HOME/Documents/Personal/Scans/Finance")
# Which vault subtrees to scan for outbound symlinks, by run scope:
#   project                -> just this project's deps (projects/<slug>)
#   author|raw             -> raw/ (ingest's symlinked sources, if any)
#   master|reader|projects -> projects/ + raw/ (everything projects rely on; interactive)
case "$PROFILE" in
  project)    SCAN_DIRS=("$PROJECT_ROOT/$WRITE_PATH") ;;
  author|raw) SCAN_DIRS=("$PROJECT_ROOT/raw") ;;
  *)          SCAN_DIRS=("$PROJECT_ROOT/projects" "$PROJECT_ROOT/raw") ;;
esac
_cands=()
for _scan in ${SCAN_DIRS[@]+"${SCAN_DIRS[@]}"}; do
  [[ -d "$_scan" ]] || continue
  while IFS= read -r _lnk; do
    _tgt="$(readlink "$_lnk")"
    if [[ "$_tgt" != /* ]]; then
      _base="$(cd "$(dirname "$_lnk")" 2>/dev/null && pwd -P)" || _base=""
      [[ -n "$_base" ]] && _tgt="$_base/$_tgt" || _tgt=""
    fi
    _tgt="${_tgt%/}"
    [[ -n "$_tgt" && -e "$_tgt" ]] || continue                              # empty/broken link
    case "$_tgt" in "$PROJECT_ROOT"|"$PROJECT_ROOT"/*) continue ;; esac     # intra-vault: already mounted
    _ok=0; for _r in "${ALLOW_ROOTS[@]}"; do [[ "$_tgt" == "$_r" || "$_tgt" == "$_r"/* ]] && { _ok=1; break; }; done
    [[ "$_ok" == 1 ]] || { echo "agent: skip un-allowlisted symlink target: $_tgt (from ${_lnk#"$PROJECT_ROOT"/})" >&2; continue; }
    _cands+=("$_tgt")
  done < <(find "$_scan" -maxdepth 5 -type l 2>/dev/null)
done
# Reduce to a minimal, deduped set: drop any target that is itself nested under another.
EXTRA_MOUNTS=()
_accepted=()
for _t in ${_cands[@]+"${_cands[@]}"}; do
  _dup=0; for _a in ${_accepted[@]+"${_accepted[@]}"}; do [[ "$_t" == "$_a" ]] && { _dup=1; break; }; done
  [[ "$_dup" == 1 ]] && continue
  _nested=0; for _o in "${_cands[@]}"; do [[ "$_t" == "$_o"/* ]] && { _nested=1; break; }; done
  [[ "$_nested" == 1 ]] && continue
  _accepted+=("$_t")
  EXTRA_MOUNTS+=(-v "$_t:$_t:ro")
done

if [[ -n "${BRAIN_DRYRUN:-}" ]]; then
  echo "profile      : $PROFILE  (label: $PROFILE_LABEL)"
  echo "writable hole: ${WRITE_PATH:-<none — read-only>}"
  echo "container    : $NAME"
  echo "volume key   : $BRAIN_VOL_KEY"
  echo "ws mounts    : ${WS_MOUNTS[*]}"
  echo "extra mounts : ${EXTRA_MOUNTS[*]-}"
  echo "command      : $*"
  exit 0
fi

# --- 2) Stage a sanitized ~/.claude -------------------------------------------
LIB="$DC/launcher-common.sh"
[[ -f "$LIB" ]] || { echo "agent: missing $LIB (run devcontainer-egress/sync.sh)." >&2; exit 1; }
# shellcheck source=/dev/null
source "$LIB"
sandbox_stage_claude_config brain

# --- 3) Build (cached) -------------------------------------------------------
container build -t "$IMAGE" "$DC" >/dev/null
# Free the ~2GB build-shim RAM now the image is built; it auto-restarts on the next
# `container build`. Set SANDBOX_KEEP_BUILDER=1 to leave it up (rapid rebuilds).
[[ -n "${SANDBOX_KEEP_BUILDER:-}" ]] || container builder stop >/dev/null 2>&1 || true

# --- 4) Idempotent run: reuse running / start stopped / else create ----------
if [[ "${BRAIN_REBUILD:-0}" == 1 ]]; then
  container rm -f "$NAME" >/dev/null 2>&1 || true
fi
if container ls -q 2>/dev/null | grep -qx "$NAME"; then
  :
elif container ls -aq 2>/dev/null | grep -qx "$NAME"; then
  container start "$NAME" >/dev/null
else
  container run -d --name "$NAME" \
    --init \
    --cap-drop ALL \
    --cap-add NET_ADMIN --cap-add CHOWN --cap-add DAC_OVERRIDE \
    --cap-add FOWNER --cap-add SETUID --cap-add SETGID \
    -m 6g -c 4 \
    --tmpfs /tmp --tmpfs /var/tmp \
    -e DEVCONTAINER=true \
    -e DISABLE_TELEMETRY=1 \
    -e DISABLE_ERROR_REPORTING=1 \
    -e BASH_ENV=/home/dev/.safe-chain/scripts/init-posix.sh \
    -e NODE_USE_ENV_PROXY=1 \
    -e HTTP_PROXY=http://127.0.0.1:3128 \
    -e HTTPS_PROXY=http://127.0.0.1:3128 \
    -e http_proxy=http://127.0.0.1:3128 \
    -e https_proxy=http://127.0.0.1:3128 \
    -e NO_PROXY=localhost,127.0.0.1,::1 \
    -e no_proxy=localhost,127.0.0.1,::1 \
    "${WS_MOUNTS[@]}" \
    -v "$PROJECT_ROOT/.git:$CONTAINER_WS/.git:ro" \
    -v "$DC:$CONTAINER_WS/.devcontainer:ro" \
    -v "brain-claude-$BRAIN_VOL_KEY:/home/dev/.claude" \
    -v "brain-local-$BRAIN_VOL_KEY:/home/dev/.local" \
    -v "brain-config-$BRAIN_VOL_KEY:/home/dev/.config" \
    -v "brain-cache-$BRAIN_VOL_KEY:/home/dev/.cache" \
    -v "$HOME/.claude-sandbox/stage/brain:/home/dev/.claude-stage:ro" \
    -v "$HOME/.claude/hooks/guard.mjs:/usr/local/share/claude-guard/guard.mjs:ro" \
    -v "$HOME/.claude/hooks/managed-settings.json:/etc/claude-code/managed-settings.json:ro" \
    -v "$HOME/.claude/projects/-Users-computer-Library-Mobile-Documents-iCloud-md-obsidian-Documents-Brain/memory:/home/dev/.claude-memory-seed:ro" \
    -v "$HOME/.cache/qmd:/home/dev/.qmd-seed:ro" \
    ${EXTRA_MOUNTS[@]+"${EXTRA_MOUNTS[@]}"} \
    "$IMAGE" >/dev/null
fi
CID="$NAME"

# Wait for the egress proxy, then replay lifecycle hooks (post-create/post-start).
container exec "$NAME" bash -lc 'for i in $(seq 1 30); do (exec 3<>/dev/tcp/127.0.0.1/3128) 2>/dev/null && break; sleep 1; done' || true

# F14: the egress allowlist is baked into the image; on the reuse/start paths the
# running container can be enforcing a stale baked copy after a sync.sh change.
sandbox_warn_stale_allowlist "$NAME" "$DC/allowlist.txt" "BRAIN_REBUILD=1 $0"
container exec --user "$SVC_USER" "$NAME" bash -lc '
  set -e
  cd '"$CONTAINER_WS"'
  if [[ ! -f /home/dev/.postcreate-done ]]; then
    bash .devcontainer/post-create.sh && touch /home/dev/.postcreate-done
  fi
  bash .devcontainer/post-start.sh'

# --- 5) Forward credentials (LLM auth only; never a git push token) -----------
EXEC_ENV=()
sandbox_forward_llm_creds brain-claude-code-token

# --- 6) Resolve the in-container working dir from the host PWD ----------------
CONTAINER_CWD="$CONTAINER_WS"
if [[ -z "${BRAIN_NO_CHDIR:-}" ]]; then
  rel="${HOST_PWD#"$PROJECT_ROOT"}"
  [[ "$rel" != "$HOST_PWD" && -n "$rel" ]] && CONTAINER_CWD="$CONTAINER_WS/${rel#/}"
fi

# --- 7) Autosync decisions ----------------------------------------------------
# MEMORY push-back (the F27 pattern) defaults ON for interactive operator sessions
# (claude/bash); a headless run's memory writes are discarded. CONFIG push-back is
# a separate, riskier container→host code-exec channel (a prompt-injected agent
# could push hooks/plugins the host Claude later runs), so it is OPT-IN even for
# the trusted Brain box: enable with BRAIN_CONFIG_AUTOSYNC=1. (F21)
AUTOSYNC="${BRAIN_AUTOSYNC:-}"
if [[ -z "$AUTOSYNC" ]]; then
  case "${1:-claude}" in claude|bash) AUTOSYNC=1 ;; *) AUTOSYNC=0 ;; esac
fi
CONFIG_AUTOSYNC="${BRAIN_CONFIG_AUTOSYNC:-0}"

# --- 8) Launch-integrity gate (mandatory; fail closed) -----------------------
# A missing checker is NOT a soft warning: the current Dockerfile always bakes
# brain-verify-pins, so its absence means a stale pre-pin image is running
# UNVERIFIED. Hard-abort and tell the operator to rebuild (matches bin/dev).
if ! container exec --user "$SVC_USER" "$NAME" bash -lc 'command -v brain-verify-pins >/dev/null 2>&1'; then
  echo "agent: ABORT — brain-verify-pins is not baked into this image (stale pre-pin image)." >&2
  echo "  The launch-integrity gate is mandatory; rebuild to bake it in: BRAIN_REBUILD=1 $0" >&2
  exit 1
fi
if ! container exec --user "$SVC_USER" -e BASH_ENV= "$NAME" brain-verify-pins --quiet; then
  echo "agent: ABORT — binary fingerprint drift (see above)." >&2
  echo "  If you intentionally upgraded a tool, rebuild to re-pin: BRAIN_REBUILD=1 $0" >&2
  exit 1
fi

# Power down the sandbox VM when this invocation ends (so it stops pinning its 6 GB)
# UNLESS BRAIN_KEEP_WARM=1 — the scheduler (dispatch.py) sets that so back-to-back
# steps in one tick reuse a single warm box and it stops them at end of tick. A
# manual brain-wiki / brain-claude / brain-shell run therefore powers its own
# container down on exit. Override explicitly with BRAIN_STOP_ON_EXIT=0|1.
if [[ "${BRAIN_KEEP_WARM:-0}" == 1 ]]; then _brain_stop=0; else _brain_stop=1; fi
sandbox_install_autosync_trap brain "$CID" "$CONFIG_AUTOSYNC" "${BRAIN_STOP_ON_EXIT:-$_brain_stop}"

# --- 9) Open the session -----------------------------------------------------
TTY_FLAGS=()
[[ -t 0 && -t 1 ]] && TTY_FLAGS=(-i -t)
set +e
container exec --user "$SVC_USER" ${TTY_FLAGS[@]+"${TTY_FLAGS[@]}"} ${EXEC_ENV[@]+"${EXEC_ENV[@]}"} \
  -e "BRAIN_CWD=$CONTAINER_CWD" "$NAME" \
  bash -c 'cd "$BRAIN_CWD" 2>/dev/null || true; exec "$@"' bash "$@"
_rc=$?

# --- 10) Push project memory back to the host (interactive sessions only) -----
if [[ "${AUTOSYNC:-0}" == 1 && -n "${CID:-}" ]]; then
  host_mem="$HOME/.claude/projects/$(printf '%s' "$PROJECT_ROOT" | sed 's/[^a-zA-Z0-9]/-/g')/memory"
  if mkdir -p "$host_mem" 2>/dev/null; then
    if container exec --user "$SVC_USER" "$NAME" \
         bash -lc 'd=/home/dev/.claude/projects/-workspaces-Brain/memory; [[ -d "$d" ]] && cd "$d" && tar -cf - . 2>/dev/null' 2>/dev/null \
       | tar -C "$host_mem" -xf - 2>/dev/null; then
      echo "agent: project memory synced back to the host (interactive session)." >&2
    fi
  fi
fi
set -e
exit "$_rc"
